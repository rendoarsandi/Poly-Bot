# PolyArb-15m Configuration

# POLYMARKET API CREDENTIALS
# Your Ethereum private key (64 hex characters)
POLY_PK=

# CLOB API credentials - Generate with: node scripts/derive-api-key.js <YOUR_PRIVATE_KEY>
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# INITIAL SETUP (Run once per wallet)
# After setting credentials, you MUST grant USDC and CTF allowances to enable trading.
# Run: go run cmd/approve/main.go

# POLYGON NETWORK
# RPC endpoint for Polygon mainnet (Alchemy, Infura, or QuickNode recommended)
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# TRADING PARAMETERS
MIN_MARGIN_PERCENT=2.0
TRADE_SCALE_FACTOR=0.05
ENABLE_MARGIN_AGGRESSION=true
MAX_AGGRESSION_MULTIPLIER=5.0

# SAFETY SETTINGS
MAX_TRADE_SIZE=50.0
REQUIRE_CONFIRM=true
TEST_MODE=true

# PAPER TRADING ONLY
FEE_RATE_BPS=312

# OPTIONAL SETTINGS
MARKET_SLUG=
ENABLE_CSV_LOGGER=false

# CTF SPLIT STRATEGY
SPLIT_STRATEGY_ENABLED=false
SPLIT_MIN_MARGIN_SELL=3.0
SPLIT_TARGET_MARGIN_RESERVE=6.0
SPLIT_REPLENISH_THRESHOLD=50.0
SPLIT_MERGE_BUFFER_SECONDS=30