# PolyArb-15m Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# TRADING MODE
# =============================================================================
# Options: "paper" (default) or "real"
# Paper mode uses simulated balance, real mode uses actual Polymarket account
TRADING_MODE=paper

# =============================================================================
# POLYMARKET API CREDENTIALS (Required for real trading)
# =============================================================================
# Your Ethereum private key (64 hex characters, with or without 0x prefix)
# NEVER share this key with anyone!
POLY_PK=your_private_key_here

# CLOB API credentials from Polymarket
# Get these from: node scripts/derive-api-key.js <YOUR_PRIVATE_KEY>
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_PASSPHRASE=your_api_passphrase_here

# =============================================================================
# POLYGON NETWORK
# =============================================================================
# RPC endpoint for Polygon mainnet
# Default: https://polygon-rpc.com (free, rate-limited)
# For better performance, use Alchemy, Infura, or QuickNode
POLYGON_RPC_URL=https://polygon-rpc.com

# =============================================================================
# SAFETY SETTINGS (Real trading only)
# =============================================================================
# Maximum USDC amount per single trade
MAX_TRADE_SIZE=50.0

# Maximum daily loss before bot stops trading
MAX_DAILY_LOSS=50.0

# Require typing 'YES' to confirm real trading
REQUIRE_CONFIRM=true

# Run in dry-run mode first (simulate API calls without placing orders)
# Set to 'false' only after testing thoroughly
DRY_RUN_FIRST=true

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================
# Specific market slug to trade (leave empty for auto-discovery)
MARKET_SLUG=

# Enable CSV logging of all bot activities (saves to bot_activity.csv)
# Warning: Can consume disk space over time
ENABLE_CSV_LOGGER=false
