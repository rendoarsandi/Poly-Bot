# PolyArb-15m Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# POLYMARKET API CREDENTIALS (Required for real trading)
# =============================================================================
# Your Ethereum private key (64 hex characters, with or without 0x prefix)
# NEVER share this key with anyone!
POLY_PK=

# CLOB API credentials - derived from your private key
# Generate with: node scripts/derive-api-key.js <YOUR_PRIVATE_KEY>
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# =============================================================================
# INITIAL SETUP (Run once per wallet)
# =============================================================================
# After setting the credentials above, you MUST grant USDC and CTF allowances
# to the Polymarket Exchange contract to enable trading.
# Run: go run cmd/approve/main.go
# =============================================================================

# =============================================================================
# POLYGON NETWORK
# =============================================================================
# RPC endpoint for Polygon mainnet (for balance queries and on-chain redemption)
# Default: https://polygon-rpc.com (free, rate-limited)
# For better performance, use Alchemy, Infura, or QuickNode
POLYGON_RPC_URL=https://polygon-rpc.com

# =============================================================================
# TRADING PARAMETERS (Used by realbot)
# =============================================================================
# Minimum arbitrage margin percentage to trade (default: 2%)
# Only trades when ask1 + ask2 <= (1 - MIN_MARGIN_PERCENT/100)
# Example: 2% means only trade when sum <= $0.98
MIN_MARGIN_PERCENT=2.0

# Fraction of balance to use per trade (default: 0.05 = 5%)
# Example: $1000 balance * 0.05 = $50 per trade
TRADE_SCALE_FACTOR=0.05

# Margin-based aggression scaling (default: true)
# Scales trade size by the margin (e.g., 2% margin = 2x size)
ENABLE_MARGIN_AGGRESSION=true
MAX_AGGRESSION_MULTIPLIER=5.0

# =============================================================================
# SAFETY SETTINGS (Real trading)
# =============================================================================
# Maximum USDC amount per single trade (caps the scaled trade size)
MAX_TRADE_SIZE=50.0

# Require typing 'YES' to confirm before starting real trading
REQUIRE_CONFIRM=true

# Test mode: validate orders (sign, check balance) but don't submit to exchange
# Set to 'false' only after thorough testing - default is 'true' for safety
TEST_MODE=true

# =============================================================================
# HARDCODED SETTINGS (Change in code if needed)
# =============================================================================
# These are currently hardcoded in cmd/realbot/main.go:
#
# Risk Config (lines 306-312):
#   MaxExposure:        Unlimited (no cap, rely on kill switch)
#   MaxUnmatchedRatio:  20%    (max imbalance before kill switch)
#   MaxUnmatchedShares: 500    (max shares on one side)
#   SkewThreshold:      10%    (triggers rebalance warning)
#   KillSwitchDrawdown: 25%    (emergency stop)
#
# Position sizing auto-compounds via equity growth (no separate multiplier)

# =============================================================================
# PAPER TRADING ONLY
# =============================================================================
# Base fee rate in basis points for paper trading fee simulation
# Not used in real trading (real fees come from API)
FEE_RATE_BPS=312

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================
MARKET_SLUG=
ENABLE_CSV_LOGGER=false

# CTF SPLIT STRATEGY (Panic Sell: SPLIT → SELL when bid_sum > $1.03)
# =============================================================================
# Strategy uses TRADE_SCALE_FACTOR for inventory sizing (same as panic buy)
SPLIT_STRATEGY_ENABLED=false
SPLIT_MIN_MARGIN_SELL=3.0
SPLIT_TARGET_MARGIN_RESERVE=6.0
SPLIT_REPLENISH_THRESHOLD=50.0
SPLIT_MERGE_BUFFER_SECONDS=30
